{
  "name": "wa-multi-instance",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "pnpm run build:ui && node scripts/copy-ui-to-public.cjs",
    "full:dev": "concurrently \"pnpm run dev\" \"pnpm run dev:ui\"",
    "full:build": "pnpm run build",
    "dev:ui": "cd ui && pnpm run dev",
    "build:ui": "cd ui && pnpm run build",
    "preview:ui": "cd ui && pnpm run preview"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "pnpm": "^11.9.0",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
